<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GlassToKey.Linux.Gui.App">
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/StatusIcon.png"
                IsVisible="True"
                ToolTipText="GlassToKey Linux"
                Clicked="OnTrayIconClicked">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Open Config" Click="OnTrayOpenClick" />
            <NativeMenuItem Header="Run Doctor" Click="OnTrayDoctorClick" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Capture .atpcap" Click="OnTrayCaptureAtpCapClick" />
            <NativeMenuItem Header="Replay .atpcap" Click="OnTrayReplayAtpCapClick" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Quit" Click="OnTrayQuitClick" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="Background" Value="#F2E8D9" />
      <Setter Property="Foreground" Value="#1E2328" />
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#5A4032" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFF9F1" />
      <Setter Property="BorderBrush" Value="#D9C7B5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background" Value="#23303A" />
      <Setter Property="Foreground" Value="#F7F2EA" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.headerAction">
      <Setter Property="Background" Value="#FFF9F1" />
      <Setter Property="Foreground" Value="#11161B" />
      <Setter Property="BorderBrush" Value="#11161B" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.headerAction:pointerover">
      <Setter Property="Background" Value="#E07845" />
      <Setter Property="Foreground" Value="#FFF9F1" />
      <Setter Property="BorderBrush" Value="#FFF9F1" />
    </Style>
  </Application.Styles>
</Application>
