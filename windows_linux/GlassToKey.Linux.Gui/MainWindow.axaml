<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GlassToKey.Linux.Gui.MainWindow"
        Width="1320"
        Height="980"
        MinWidth="1180"
        MinHeight="860"
        Title="GlassToKey Linux Control">
  <Grid RowDefinitions="Auto,*">
    <Border Background="#23303A" Padding="24,18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="GlassToKey Linux"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#F7F2EA" />
          <TextBlock Text="Device binding, diagnostics, and runtime service control"
                     FontSize="14"
                     Foreground="#D9C7B5" />
        </StackPanel>
        <Border Background="#E07845"
                CornerRadius="12"
                Padding="14,8"
                VerticalAlignment="Center">
          <TextBlock x:Name="PhaseBadgeText"
                     Text="Phase 4 / 6"
                     FontWeight="SemiBold"
                     Foreground="#FFF7F0" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="24"
          ColumnDefinitions="2*,1.25*">
      <StackPanel Spacing="18">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Trackpads" />

            <TextBlock Text="Left trackpad" />
            <ComboBox x:Name="LeftDeviceCombo" MinWidth="320" />

            <TextBlock Text="Right trackpad" Margin="0,8,0,0" />
            <ComboBox x:Name="RightDeviceCombo" MinWidth="320" />

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button x:Name="RefreshDevicesButton" Classes="action" Content="Refresh Devices" />
              <Button x:Name="SwapSidesButton" Content="Swap Sides" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Runtime Owner" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button x:Name="StartRuntimeButton" Classes="action" Content="Start Runtime" />
              <Button x:Name="StopRuntimeButton" Content="Stop Runtime" />
            </StackPanel>
            <TextBlock x:Name="RuntimeSummaryText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />
            <TextBlock x:Name="RuntimeBindingsText"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <TextBlock Text="Layout preset" />
            <ComboBox x:Name="LayoutPresetCombo" MinWidth="240" />

            <TextBlock Text="Keymap path" Margin="0,8,0,0" />
            <TextBox x:Name="KeymapPathBox" Watermark="Use bundled Linux default when empty" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button x:Name="BrowseKeymapButton" Content="Browse Keymap" />
              <Button x:Name="ClearKeymapButton" Content="Use Bundled Default" />
            </StackPanel>
            <TextBlock x:Name="KeymapStatusText"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <TextBlock x:Name="SettingsPathText"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button x:Name="SaveSettingsButton" Classes="action" Content="Save Settings" />
              <Button x:Name="InitializeDefaultsButton" Content="Init Defaults" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Live Input Preview" />
            <TextBlock Text="Reads evdev directly for diagnostics so you can inspect contact motion without moving the runtime owner onto the GUI hotpath."
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button x:Name="StartPreviewButton" Classes="action" Content="Start Preview" />
              <Button x:Name="StopPreviewButton" Content="Stop Preview" />
            </StackPanel>

            <TextBlock x:Name="PreviewSummaryText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />

            <Border Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
              <StackPanel Spacing="8">
                <TextBlock Text="Left Trackpad"
                           FontWeight="SemiBold"
                           Foreground="#5A4032" />
                <Canvas x:Name="LeftPreviewCanvas"
                        Width="600"
                        Height="360"
                        Background="#FFF9F1" />
                <TextBlock x:Name="LeftPreviewText"
                           TextWrapping="Wrap"
                           Foreground="#5A4032" />
              </StackPanel>
            </Border>

            <Border Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
              <StackPanel Spacing="8">
                <TextBlock Text="Right Trackpad"
                           FontWeight="SemiBold"
                           Foreground="#5A4032" />
                <Canvas x:Name="RightPreviewCanvas"
                        Width="600"
                        Height="360"
                        Background="#FFF9F1" />
                <TextBlock x:Name="RightPreviewText"
                           TextWrapping="Wrap"
                           Foreground="#5A4032" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Loaded Keymap" />
            <TextBlock Text="Renders the current preset and loaded key labels from the active keymap so the config UI reflects what the runtime should be using."
                       TextWrapping="Wrap"
                       Foreground="#5A4032" />

            <Grid ColumnDefinitions="*,*">
              <Border Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Left Layout"
                             FontWeight="SemiBold"
                             Foreground="#5A4032" />
                  <Canvas x:Name="LeftKeymapCanvas"
                          Width="300"
                          Height="220"
                          Background="#FFF9F1" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Margin="12,0,0,0" Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Right Layout"
                             FontWeight="SemiBold"
                             Foreground="#5A4032" />
                  <Canvas x:Name="RightKeymapCanvas"
                          Width="300"
                          Height="220"
                          Background="#FFF9F1" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="1" Spacing="18" Margin="18,0,0,0">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Resolved State" />
            <TextBlock x:Name="ResolvedBindingsText"
                       TextWrapping="Wrap"
                       FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter" />
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Warnings / Notes" />
            <TextBlock x:Name="WarningsText"
                       TextWrapping="Wrap"
                       Foreground="#6A4533" />
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="section" Text="Diagnostics" />
              <Button x:Name="RunDoctorButton"
                      Grid.Column="1"
                      Classes="action"
                      Content="Run Doctor" />
            </Grid>
            <TextBox x:Name="DoctorReportBox"
                     Height="220"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter" />
          </StackPanel>
        </Border>

        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Status" />
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       Foreground="#23303A" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
