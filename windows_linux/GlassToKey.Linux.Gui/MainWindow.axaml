<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GlassToKey.Linux.Gui.MainWindow"
        Width="2640"
        Height="1376"
        MinWidth="1800"
        MinHeight="660"
        Title="GlassToKey Linux Control">
  <Window.Resources>
    <x:Double x:Key="TrackpadPreviewInnerWidth">700</x:Double>
    <x:Double x:Key="TrackpadPreviewInnerHeight">420</x:Double>
  </Window.Resources>
  <Grid RowDefinitions="Auto,*">
    <Border Background="#23303A" Padding="24,18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="GlassToKey Linux"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#F7F2EA" />
          <TextBlock Text="Device binding and config for the tray-owned Linux runtime"
                     FontSize="14"
                     Foreground="#D9C7B5" />
          <TextBlock x:Name="RuntimeTypingStatusText"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#F7F2EA"
                     Text="Typing: checking runtime..." />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Spacing="10"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="10">
            <Button x:Name="ImportSettingsButton" Classes="headerAction" Content="Import Settings" />
            <Button x:Name="ExportSettingsButton" Classes="headerAction" Content="Export Settings" />
          </StackPanel>
          <StackPanel x:Name="ReplayPanel"
                      IsVisible="False"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="10">
            <Button x:Name="ReplayToggleButton"
                    Classes="headerAction"
                    Content="Play" />
            <TextBlock Text="Speed"
                       VerticalAlignment="Center"
                       Foreground="#F7F2EA" />
            <ComboBox x:Name="ReplaySpeedCombo"
                      Width="90"
                      MinWidth="90" />
            <Slider x:Name="ReplayTimelineSlider"
                    Width="320"
                    Minimum="0"
                    Maximum="1000"
                    VerticalAlignment="Center" />
            <TextBlock x:Name="ReplayTimeText"
                       VerticalAlignment="Center"
                       Foreground="#F7F2EA"
                       Text="0.00s / 0.00s" />
            <Button x:Name="ReplayCloseButton"
                    Content="Close Replay" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  Margin="24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,*,Auto">
              <StackPanel Spacing="8">
                <TextBlock Text="Left trackpad" />
                <ComboBox x:Name="LeftDeviceCombo" MinWidth="320" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
                <TextBlock Text="Right trackpad" />
                <ComboBox x:Name="RightDeviceCombo" MinWidth="320" />
              </StackPanel>
              <Button x:Name="RefreshDevicesButton"
                      Grid.Column="2"
                      Margin="16,28,0,0"
                      VerticalAlignment="Top"
                      Classes="action"
                      Content="Refresh Devices" />
            </Grid>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="2.8*,0.9*">
          <Border Classes="panel">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,*">
                <Border Background="#FFF3E6"
                        BorderBrush="#D9C7B5"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10"
                        MinWidth="{StaticResource TrackpadPreviewInnerWidth}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Left Trackpad"
                               FontWeight="SemiBold"
                               Foreground="#5A4032" />
                    <Canvas x:Name="LeftPreviewCanvas"
                            Width="{StaticResource TrackpadPreviewInnerWidth}"
                            MinWidth="{StaticResource TrackpadPreviewInnerWidth}"
                            Height="{StaticResource TrackpadPreviewInnerHeight}"
                            Background="#FFF9F1" />
                    <TextBlock x:Name="LeftPreviewText"
                               TextWrapping="Wrap"
                               Foreground="#5A4032" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Background="#FFF3E6"
                        BorderBrush="#D9C7B5"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10"
                        MinWidth="{StaticResource TrackpadPreviewInnerWidth}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Right Trackpad"
                               FontWeight="SemiBold"
                               Foreground="#5A4032" />
                    <Canvas x:Name="RightPreviewCanvas"
                            Width="{StaticResource TrackpadPreviewInnerWidth}"
                            MinWidth="{StaticResource TrackpadPreviewInnerWidth}"
                            Height="{StaticResource TrackpadPreviewInnerHeight}"
                            Background="#FFF9F1" />
                    <TextBlock x:Name="RightPreviewText"
                               TextWrapping="Wrap"
                               Foreground="#5A4032" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Background="#0C0F12"
                      BorderBrush="#2B2F33"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="12,10"
                      Margin="0,8,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Typing Test"
                             Foreground="#8B949E"
                             FontSize="12" />
                  <TextBox x:Name="TypingTestBox"
                           Height="80"
                           AcceptsReturn="True"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="panel" Margin="18,0,0,0">
            <StackPanel Spacing="12"
                        HorizontalAlignment="Stretch">
              <TextBlock Classes="section" Text="Settings" />
              <TextBlock Text="Layout preset" />
              <ComboBox x:Name="LayoutPresetCombo" MinWidth="260" />
              <Separator Margin="0,6,0,2" />
              <Expander Header="5-finger swipe"
                        IsExpanded="True"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      Margin="0,10,0,0"
                      HorizontalAlignment="Stretch">
                  <TextBlock Text="Left"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="FiveFingerSwipeLeftCombo"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            MinWidth="220" />
                  <TextBlock Grid.Row="1"
                             Margin="0,8,0,0"
                             Text="Right"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="FiveFingerSwipeRightCombo"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="10,8,0,0"
                            MinWidth="220" />
                  <TextBlock Grid.Row="2"
                             Margin="0,8,0,0"
                             Text="Up"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="FiveFingerSwipeUpCombo"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="10,8,0,0"
                            MinWidth="220" />
                  <TextBlock Grid.Row="3"
                             Margin="0,8,0,0"
                             Text="Down"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="FiveFingerSwipeDownCombo"
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="10,8,0,0"
                            MinWidth="220" />
                </Grid>
              </Expander>
              <Separator Margin="0,6,0,2" />
              <Expander Header="Keymap Editing"
                        IsExpanded="True"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="10"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch">
                  <TextBlock Text="Click a key or custom button on the preview to edit."
                             TextWrapping="Wrap"
                             Foreground="#6A4533" />
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        RowDefinitions="Auto">
                    <TextBlock Text="Layer"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="KeymapLayerCombo"
                              Grid.Column="1"
                              Margin="10,0,10,0"
                              MinWidth="110" />
                    <Button x:Name="KeymapClearSelectionButton"
                            Grid.Column="2"
                            Content="Clear" />
                  </Grid>
                  <TextBlock x:Name="KeymapSelectionText"
                             TextWrapping="Wrap"
                             Foreground="#5A4032"
                             Text="Selection: none" />
                  <TextBlock Text="Primary Action" />
                  <ComboBox x:Name="KeymapPrimaryCombo" />
                  <TextBlock Text="Hold Action (optional)" />
                  <ComboBox x:Name="KeymapHoldCombo" />
                  <Grid ColumnDefinitions="Auto,*"
                        RowDefinitions="Auto">
                    <TextBlock Text="Key Rotation (deg)"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="KeyRotationBox"
                             Grid.Column="1"
                             Margin="10,0,0,0" />
                  </Grid>
                  <TextBlock Text="Custom Buttons"
                             FontWeight="SemiBold"
                             Margin="0,2,0,0" />
                  <Grid ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto">
                    <Button x:Name="CustomButtonAddLeftButton"
                            Content="Add Left" />
                    <Button x:Name="CustomButtonAddRightButton"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="Add Right" />
                    <Button x:Name="CustomButtonDeleteButton"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,8,0,0"
                            Content="Delete Selected" />
                  </Grid>
                  <Grid ColumnDefinitions="Auto,*"
                        RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Text="X (%)"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CustomButtonXBox"
                             Grid.Column="1"
                             Margin="10,0,0,0" />
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Text="Y (%)"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CustomButtonYBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="10,8,0,0" />
                    <TextBlock Grid.Row="2"
                               Margin="0,8,0,0"
                               Text="Width (%)"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CustomButtonWidthBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="10,8,0,0" />
                    <TextBlock Grid.Row="3"
                               Margin="0,8,0,0"
                               Text="Height (%)"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CustomButtonHeightBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Margin="10,8,0,0" />
                  </Grid>
                </StackPanel>
              </Expander>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </ScrollViewer>

    <Border x:Name="NoticeOverlay"
            Grid.RowSpan="2"
            IsVisible="False"
            Background="#660C0F12">
      <Grid HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border Background="#FFF9F1"
                BorderBrush="#D9C7B5"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18"
                Width="620"
                MaxWidth="620">
          <StackPanel Spacing="14">
            <TextBlock x:Name="NoticeTitleText"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1E2328" />
            <TextBlock x:Name="NoticeMessageText"
                       TextWrapping="Wrap"
                       Foreground="#1E2328" />
            <Button x:Name="NoticeCloseButton"
                    HorizontalAlignment="Right"
                    Classes="action"
                    Content="Close" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
