<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GlassToKey.Linux.Gui.MainWindow"
        Width="2640"
        Height="1960"
        MinWidth="1800"
        MinHeight="1100"
        Title="GlassToKey Linux Control">
  <Grid RowDefinitions="Auto,*">
    <Border Background="#23303A" Padding="24,18">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="GlassToKey Linux"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#F7F2EA" />
          <TextBlock Text="Device binding and config for the tray-owned Linux runtime"
                     FontSize="14"
                     Foreground="#D9C7B5" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <Button x:Name="ImportSettingsButton" Classes="headerAction" Content="Import Settings" />
          <Button x:Name="ExportSettingsButton" Classes="headerAction" Content="Export Settings" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  Margin="24"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="18">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Trackpads" />
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Spacing="8">
                <TextBlock Text="Left trackpad" />
                <ComboBox x:Name="LeftDeviceCombo" MinWidth="320" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
                <TextBlock Text="Right trackpad" />
                <ComboBox x:Name="RightDeviceCombo" MinWidth="320" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button x:Name="RefreshDevicesButton" Classes="action" Content="Refresh Devices" />
              <Button x:Name="SwapSidesButton" Content="Swap Sides" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="2.35*,1*">
          <Border Classes="panel">
            <StackPanel Spacing="12">
              <TextBlock Classes="section" Text="Live Input Preview" />
              <TextBlock Text="Reads evdev directly so you can inspect contact motion against the active loaded keymap while the tray-owned runtime stays off the GUI hotpath."
                         TextWrapping="Wrap"
                         Foreground="#5A4032" />

              <TextBlock x:Name="PreviewSummaryText"
                         TextWrapping="Wrap"
                         Foreground="#23303A" />

              <Grid ColumnDefinitions="*,*">
                <Border Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Left Trackpad"
                               FontWeight="SemiBold"
                               Foreground="#5A4032" />
                    <Canvas x:Name="LeftPreviewCanvas"
                            Width="700"
                            Height="420"
                            Background="#FFF9F1" />
                    <TextBlock x:Name="LeftPreviewText"
                               TextWrapping="Wrap"
                               Foreground="#5A4032" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="12,0,0,0" Background="#FFF3E6" BorderBrush="#D9C7B5" BorderThickness="1" CornerRadius="12" Padding="10">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Right Trackpad"
                               FontWeight="SemiBold"
                               Foreground="#5A4032" />
                    <Canvas x:Name="RightPreviewCanvas"
                            Width="700"
                            Height="420"
                            Background="#FFF9F1" />
                    <TextBlock x:Name="RightPreviewText"
                               TextWrapping="Wrap"
                               Foreground="#5A4032" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border Background="#0C0F12"
                      BorderBrush="#2B2F33"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="12,10"
                      Margin="0,8,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Typing Test"
                             Foreground="#8B949E"
                             FontSize="12" />
                  <TextBox x:Name="TypingTestBox"
                           Height="80"
                           AcceptsReturn="True"
                           TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="panel" Margin="18,0,0,0">
            <StackPanel Spacing="12">
              <TextBlock Classes="section" Text="Settings" />
              <TextBlock Text="Layout preset" />
              <ComboBox x:Name="LayoutPresetCombo" MinWidth="260" />
            </StackPanel>
          </Border>
        </Grid>

        <TextBlock x:Name="StatusText"
                   TextWrapping="Wrap"
                   Foreground="#23303A" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
